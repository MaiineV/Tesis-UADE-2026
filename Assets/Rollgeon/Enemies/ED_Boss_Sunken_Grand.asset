  EntityId: boss.sunken_grand
  DisplayName: The Sunken Grand
  Description: 'He has been calculating odds in the casino for centuries. He doesn''t
    need to guess what combo the player is going to roll: it is enough for him to
    take a part of the equation out of it. He speaks during combat making cool statistical
    observations about the player''s roll. He''s not cruel, he''s an actuary who
    never learned to shut up.'
  WeaknessComboId: 
  WeaknessMultiplierOverride: 0
  BaseHP: 100
  BaseAttack: 2
  BaseHealStrength: 3
  BaseSpeed: 5
  MaxEnergy: 3
  VisualPrefab: {fileID: 5047352166231496340, guid: e9fa077d66130974b8ee953161b1b85f, type: 3}
  MinGoldDrop: 15
  MaxGoldDrop: 23
